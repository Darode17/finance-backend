# Copy this to .env and adjust as needed (optional, all have defaults)

# Server port (default: 8080)
PORT=8080

# JWT signing secret — change this in any non-local environment
JWT_SECRET=finance-backend-secret-key-change-in-production

# SQLite database file path (default: finance.db in project root)
DB_PATH=finance.db

# Gin mode: debug | release (default: debug)
GIN_MODE=debug
